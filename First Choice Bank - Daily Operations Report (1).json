      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Get clean data from previous node\nconst data = $input.first().json;\n\n// Format date nicely\nconst reportDate = data.date;\n\n// Build Markdown table for Slack\nconst markdownReport = `📊 *First Choice Bank — Daily Operations Report*\n*Date: ${reportDate}*\n\n| Metric | Count |\n|---|---|\n| 🎫 Chatbot Tickets | ${data.tickets} |\n| 📞 Voice Agent Calls | ${data.calls} |\n| 😠 Complaints | ${data.complaints} |\n| ⚠️ SLA Breaches | ${data.sla_breaches} |\n\n_Powered by IGC Automation_ 🤖`;\n\n// Build summary prompt for AI Agent\nconst summaryPrompt = `You are a bank operations analyst.\nWrite exactly ONE sentence summarizing this data:\n- Chatbot Tickets: ${data.tickets}\n- Voice Agent Calls: ${data.calls}\n- Complaints: ${data.complaints}\n- SLA Breaches: ${data.sla_breaches}\n\nFocus on the most critical metric.\nBe professional and concise.`;\n\n// Return formatted data\nreturn [{\njson: {\n...data,\nmarkdown_report: markdownReport,\nsummary_prompt: summaryPrompt,\nreport_date: reportDate\n}\n}];"
      },
