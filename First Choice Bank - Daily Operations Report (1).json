    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Get incoming data from Google Sheets\nconst data = $input.first().json;\n\n// Clean and fill missing values\n// If a field is empty, null or undefined\n// replace it with a default value\n\nconst date = data.Date || 'Unknown';\nconst tickets = data.Tickets !== '' &&\ndata.Tickets !== null &&\ndata.Tickets !== undefined\n? Number(data.Tickets) : 0;\n\nconst calls = data.Calls !== '' &&\ndata.Calls !== null &&\ndata.Calls !== undefined\n? Number(data.Calls) : 0;\n\nconst complaints = data.Complaints !== '' &&\ndata.Complaints !== null &&\ndata.Complaints !== undefined\n? Number(data.Complaints) : 0;\n\nconst sla_breaches = data.SLA_Breaches !== '' &&\ndata.SLA_Breaches !== null &&\ndata.SLA_Breaches !== undefined\n? Number(data.SLA_Breaches) : 0;\n\n// Return clean data\nreturn [{\njson: {\ndate,\ntickets,\ncalls,\ncomplaints,\nsla_breaches,\nis_sanitized: true\n}\n}];"
      },
